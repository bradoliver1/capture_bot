# ---- Capture Bot configuration ----
# Copy to ".env" and fill in. Never commit the real .env.

# 1. Telegram bot token from @BotFather
TELEGRAM_TOKEN=

# 2. Anthropic API key (classifies + structures each item)
#    https://console.anthropic.com
ANTHROPIC_API_KEY=

# 3. OpenAI API key (Whisper voice transcription)
#    https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 4. Notion internal integration token (and share the Capture Inbox with it)
#    https://www.notion.so/profile/integrations
NOTION_TOKEN=

# Your private Capture Inbox (already created — don't change)
NOTION_DB_ID=0dc1947f-53ce-43b9-bb0d-e5de1852aa00

# Lock the bot to you. Leave blank on first run; message the bot, it replies your
# chat ID; paste it here and restart.
AUTHORIZED_CHAT_ID=

# ---- Call tier (Twilio) — optional but it's the "break through a meeting" piece ----
# Leave all four blank to skip calls (urgent items fall back to a loud Telegram ping).
#   https://console.twilio.com  (Account SID + Auth Token on the dashboard)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # the Twilio number you buy, e.g. +16155551234
MY_PHONE_NUMBER=           # your cell, e.g. +16155559876

# Minutes before the event to call you (so you have time to wrap up).
CALL_LEAD_MINUTES=5

# Times of day to re-surface open, due items (escalation). 24h, comma-separated.
NUDGE_TIMES=08:00,13:00,16:30

# Timezone for resolving "tomorrow", "3:15", etc.
TZ=America/Chicago

CLAUDE_MODEL=claude-haiku-4-5-20251001
REMINDER_DB_PATH=reminders.db
